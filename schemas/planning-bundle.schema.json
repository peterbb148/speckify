{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/peterbb148/speckify/schemas/planning-bundle.schema.json",
  "title": "PlanningBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_metadata",
    "source_summary",
    "source_anchors",
    "spec_units",
    "implementation_units",
    "verification_units",
    "trace_bundles",
    "dependency_edges",
    "assembly_rules",
    "unresolved_ambiguities",
    "rendered_issues"
  ],
  "properties": {
    "bundle_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "schema_version",
        "bundle_version",
        "generated_at"
      ],
      "properties": {
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "bundle_version": {
          "type": "integer",
          "minimum": 1
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "source_model_id": {
          "type": "string",
          "minLength": 1
        },
        "source_model_version": {
          "type": [
            "integer",
            "string"
          ]
        },
        "decomposition_profile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_system",
        "project_id"
      ],
      "properties": {
        "source_system": {
          "type": "string",
          "minLength": 1
        },
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "project_name": {
          "type": "string",
          "minLength": 1
        },
        "export_version": {
          "type": [
            "integer",
            "string"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_anchors": {
      "type": "array",
      "items": {
        "$ref": "./source-anchor.schema.json"
      }
    },
    "spec_units": {
      "type": "array",
      "items": {
        "$ref": "./spec-unit.schema.json"
      }
    },
    "implementation_units": {
      "type": "array",
      "items": {
        "$ref": "./implementation-unit.schema.json"
      }
    },
    "verification_units": {
      "type": "array",
      "items": {
        "$ref": "./verification-unit.schema.json"
      }
    },
    "trace_bundles": {
      "type": "array",
      "items": {
        "$ref": "./trace-bundle.schema.json"
      }
    },
    "dependency_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "from_implementation_unit_id",
          "to_implementation_unit_id",
          "dependency_type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "from_implementation_unit_id": {
            "type": "string",
            "minLength": 1
          },
          "to_implementation_unit_id": {
            "type": "string",
            "minLength": 1
          },
          "dependency_type": {
            "type": "string",
            "enum": [
              "blocks",
              "requires",
              "soft_sequence"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assembly_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source_anchor_ids",
          "member_spec_unit_ids",
          "rule_type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source_anchor_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "member_spec_unit_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rule_type": {
            "type": "string",
            "enum": [
              "conjunctive_set",
              "ordered_sequence",
              "constraint_overlay",
              "state_guarded_behavior"
            ]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "unresolved_ambiguities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ambiguity_id",
          "status",
          "blocking"
        ],
        "properties": {
          "ambiguity_id": {
            "type": "string",
            "minLength": 1
          },
          "affects_implementation_unit_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    },
    "rendered_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "implementation_unit_id",
          "issue_title",
          "issue_body"
        ],
        "properties": {
          "implementation_unit_id": {
            "type": "string",
            "minLength": 1
          },
          "issue_title": {
            "type": "string",
            "minLength": 1
          },
          "issue_body": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
