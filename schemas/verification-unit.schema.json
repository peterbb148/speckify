{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/peterbb148/speckify/schemas/verification-unit.schema.json",
  "title": "VerificationUnit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "implementation_unit_id",
    "title",
    "verification_intent",
    "source_anchor_ids",
    "observables",
    "expected_outcomes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "implementation_unit_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "verification_intent": {
      "type": "string",
      "minLength": 1
    },
    "source_anchor_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "observables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "setup_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invariants_preserved": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
