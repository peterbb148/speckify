{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/peterbb148/speckify/schemas/spec-unit.schema.json",
  "title": "SpecUnit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "summary",
    "source_anchor_ids",
    "obligation_kind"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "source_anchor_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "obligation_kind": {
      "type": "string",
      "minLength": 1
    },
    "normative": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
