{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/peterbb148/speckify/schemas/trace-bundle.schema.json",
  "title": "TraceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_anchor_ids",
    "spec_unit_ids",
    "implementation_unit_ids",
    "verification_unit_ids"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source_anchor_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "spec_unit_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "implementation_unit_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification_unit_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assembly_rule_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
